# Public site URL used for robots.txt, sitemap.xml and social metadata.
# Set this to your production Vercel/custom domain.
VITE_SITE_URL=https://vpn-diagnostics.vercel.app

# Use this for GitHub Pages project sites, for example:
# VITE_BASE_PATH=/vpn_diagnostics/
VITE_BASE_PATH=/

# Frontend API endpoints.
# For Vercel frontend + separately hosted backend, set both in Vercel Project Settings.
VITE_API_BASE=https://your-backend.example.com
VITE_WS_BASE=wss://your-backend.example.com
